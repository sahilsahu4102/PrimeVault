		{
			"name": "Assets",
			"item": [
				{
					"name": "Get All Assets",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{ACCESS_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/v1/assets?page=1&limit=10",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"v1",
								"assets"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "10"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Create Asset",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{ACCESS_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Wrapped Ethereum Pool\",\n    \"description\": \"Liquid staking protocol token wrapper.\",\n    \"volume\": 5500000,\n    \"category\": \"DeFi\",\n    \"stock\": 1000\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/api/v1/assets",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"v1",
								"assets"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "BASE_URL",
			"value": "http://localhost:5000"
		},
		{
